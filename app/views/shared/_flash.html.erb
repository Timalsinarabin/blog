<% if flash[:notice] %>
    <div class="alert alert-primary w-75 end-0 position-absolute m-4" role="alert">
        <%= flash[:notice]%>
    </div>
<%end%>
<% if flash[:alert] %>
    <div class="alert alert-danger w-75 end-0 position-absolute m-4" role="alert">
        <%= flash[:alert]%>
    </div>
<%end%>